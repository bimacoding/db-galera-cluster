[mysqld]
binlog_format=ROW
default-storage-engine=innodb
innodb_autoinc_lock_mode=2
bind-address=0.0.0.0

# ============================================================
# MariaDB Galera Cluster Configuration
# ============================================================
wsrep_on=ON
wsrep_provider=/usr/lib/galera/libgalera_smm.so
wsrep_cluster_name="{{ mariadb_cluster_name }}"
wsrep_cluster_address="gcomm://{{ groups['mariadb_cluster'] | map('extract', hostvars, ['interface_ip']) | default(groups['mariadb_cluster'] | map('extract', hostvars, ['ansible_default_ipv4', 'address']), true) | join(',') }}"
wsrep_sst_method=mariabackup

# PERBAIKAN KRITIS: wsrep_sst_auth WAJIB ada. Tanpa baris ini, proses
# SST (State Snapshot Transfer) saat node baru join atau resync akan
# SELALU gagal dengan error autentikasi "Access denied for user
# 'mariabackup'", walau user mariabackup sudah dibuat di MySQL,
# karena mariabackup butuh kredensial ini untuk koneksi donor->joiner.
wsrep_sst_auth="mariabackup:{{ mariadb_sst_password }}"

wsrep_node_address="{{ interface_ip }}"
wsrep_node_name="{{ inventory_hostname }}"

# MariaDB Galera mode strict
wsrep_provider_options="base_port=4567; gmcast.segment=0; pc.announce_timeout=PT15S; evs.keepalive_period=PT3S; evs.suspect_timeout=PT1M30S; evs.inactive_timeout=PT3M; evs.install_timeout=PT1M; evs.send_window=4; evs.user_send_window=2"

# Catatan: pastikan firewall membuka port berikut antar-node cluster:
#   3306/tcp  - koneksi client/HAProxy
#   4567/tcp+udp - replikasi Galera (gcomm)
#   4568/tcp  - IST (Incremental State Transfer)
#   4444/tcp  - SST (State Snapshot Transfer via mariabackup)

# InnoDB Performance Tuning
innodb_buffer_pool_size={{ mariadb_innodb_buffer_pool_size | default('1G') }}
innodb_log_file_size=256M
innodb_flush_log_at_trx_commit=1
innodb_flush_method=O_DIRECT
innodb_doublewrite=ON
innodb_file_per_table=1
innodb_autoinc_lock_mode=2

# Connection & Thread Pool
max_allowed_packet={{ mariadb_max_allowed_packet | default('512M') }}
key_buffer_size={{ mariadb_key_buffer_size | default('256M') }}
max_connections={{ mariadb_max_connections | default('500') }}
thread_cache_size=128

# Character Set
character-set-server=utf8mb4
collation-server=utf8mb4_unicode_ci

[client]
default-character-set=utf8mb4

[mysql]
default-character-set=utf8mb4
