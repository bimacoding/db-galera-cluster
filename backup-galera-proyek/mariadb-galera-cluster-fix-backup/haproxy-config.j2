global
    log	/dev/log	local0
    log	/dev/log	local1 notice
    chroot	/var/lib/haproxy
    stats	socket /run/haproxy/admin.sock mode 660 level admin
    stats	timeout 30s
    user	haproxy
    group	haproxy
    daemon

    # Default SSL material locations
    ca-base	/etc/ssl/certs
    crt-base	/etc/ssl/private

    # Default ciphers untuk socket listening yang SSL-enabled.
    ssl-default-bind-ciphers ECDH+AESGCM:DH+AESGCM:ECDH+AES256:DH+AES256:ECDH+AES128:DH+AES:ECDH+3DES:DH+3DES:RSA+AESGCM:RSA+AES:RSA+3DES:!aNULL:!MD5:!DSS
    ssl-default-bind-options no-sslv3

defaults
    log	global
    option	dontlognull
    option	redispatch
    retries	3
    timeout connect 5000
    timeout client  50000
    timeout server  50000
    errorfile 400 /etc/haproxy/errors/400.http
    errorfile 403 /etc/haproxy/errors/403.http
    errorfile 408 /etc/haproxy/errors/408.http
    errorfile 500 /etc/haproxy/errors/500.http
    errorfile 502 /etc/haproxy/errors/502.http
    errorfile 503 /etc/haproxy/errors/503.http
    errorfile 504 /etc/haproxy/errors/504.http

# Stats dashboard
# PERBAIKAN: bind ke 0.0.0.0 bukan ansible_default_ipv4.address.
# Pada server multi-NIC (umum di VPS cloud: NIC publik + privat),
# ansible_default_ipv4 bisa salah pilih interface sehingga dashboard
# stats tidak bisa diakses sama sekali. Batasi akses lewat firewall
# (ufw/iptables), bukan lewat bind address.
listen stats
    bind 0.0.0.0:8404
    mode http
    stats enable
    stats uri /
    stats refresh 10s
    stats auth {{ haproxy_stats_user | default('admin') }}:{{ haproxy_stats_password }}
    stats admin if TRUE

# Load Balancing untuk MariaDB Galera Cluster
listen mariadb_galera_cluster
    bind 0.0.0.0:3306
    balance roundrobin
    mode tcp
    option tcpka
    # PERBAIKAN: "option mysql-check" sering tidak akurat di MariaDB
    # versi baru (10.5+) karena perubahan handshake protocol. Pakai
    # tcp-check sederhana (cek port terbuka) yang jauh lebih andal,
    # dikombinasikan dengan user haproxy yang tetap dibuat untuk
    # kompatibilitas mendatang.
    option tcp-check
    tcp-check connect port 3306
    {% for host in groups['mariadb_cluster'] %}
    server {{ hostvars[host]['inventory_hostname'] }} {{ hostvars[host]['interface_ip'] | default(hostvars[host]['ansible_default_ipv4']['address']) }}:3306 check weight 1
    {% endfor %}
